{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@agendaslim/gestor...",
  "outputDirectory": ".vercel/output",
  "crons": [
    { "path": "/api/cron/expire-holds", "schedule": "*/1 * * * *" },
    { "path": "/api/cron/reprocess-webhooks", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/sync-payments", "schedule": "*/5 * * * *" }
  ]
}
