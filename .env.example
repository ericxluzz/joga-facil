# ============================================================
# Agenda-Slim · Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# --- App ---
NUXT_PUBLIC_APP_URL=http://localhost:3000
NUXT_PUBLIC_CLIENT_URL=http://localhost:3001

# --- Supabase ---
# Crie um projeto em https://supabase.com e pegue as credenciais em Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Postgres direto via Drizzle) ---
# Em Supabase: Project Settings > Database > Connection string (Pooler — Transaction)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agendaslim
DATABASE_URL_POOLER=

# --- Upstash Redis (hold de slots) ---
# https://upstash.com/ — free tier 10k cmd/dia
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- AbacatePay (PIX) ---
# https://abacatepay.com/ — sandbox gratuito
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_ENV=sandbox

# --- Resend (e-mail) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Agenda-Slim <noreply@agenda-slim.com.br>

# --- Trigger.dev (jobs) ---
TRIGGER_API_KEY=
TRIGGER_API_URL=https://api.trigger.dev

# --- OneSignal (push PWA) ---
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# --- Observabilidade ---
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Flags de dev ---
# Use mock=1 para rodar sem dependências externas (apenas dev/scaffold)
MOCK_AUTH=1
MOCK_PAYMENTS=1
MOCK_EMAIL=1
