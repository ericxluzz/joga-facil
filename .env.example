# ============================================================
# Agenda-Slim · Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# --- App ---
NUXT_PUBLIC_APP_URL=http://localhost:3000
NUXT_PUBLIC_CLIENT_URL=http://localhost:3001

# --- Supabase (gestor usa SUPABASE_KEY; cliente pode usar SUPABASE_ANON_KEY) ---
# Settings > API no painel Supabase
SUPABASE_URL=
SUPABASE_KEY=
# alias aceito pelo gestor se preferir este nome:
SUPABASE_ANON_KEY=
# APENAS server-side — nunca NUXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase Storage ---
# Bucket privado para documentos KYC (criar no Supabase Storage)
SUPABASE_STORAGE_BUCKET_KYC=tenant-kyc

# --- Database (APENAS local — migrations Drizzle) ---
# Na Vercel, o banco é acessado via SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (HTTP/PostgREST).
# DATABASE_URL só é necessário localmente para rodar migrations: pnpm db:migrate
DATABASE_URL=postgresql://postgres:SENHA@db.SEU_REF.supabase.co:6543/postgres

# --- ValidaPay (PIX com split) ---
# Obtenha no painel: https://validapay.com.br
# Use VALIDAPAY_ACCESS_TOKEN (mais simples) OU CLIENT_ID+SECRET (OAuth automático)
VALIDAPAY_ACCESS_TOKEN=
VALIDAPAY_CLIENT_ID=
VALIDAPAY_CLIENT_SECRET=
VALIDAPAY_WEBHOOK_SECRET=
VALIDAPAY_ENV=sandbox
# URL base (deixar vazio para usar o padrão sandbox/production baseado em VALIDAPAY_ENV)
VALIDAPAY_API_BASE_URL=
# Conta principal da plataforma (master account)
VALIDAPAY_MASTER_ACCOUNT_NUMBER=
# Fallback para dev (subconta padrão) — NÃO usar em produção
VALIDAPAY_DEFAULT_ACCOUNT_ID=

# Taxa da plataforma por reserva (em centavos) — padrão: 500 = R$5,00
PLATFORM_FEE_CENTS=500
# % do sinal no checkout parcial — padrão: 50
DEPOSIT_PERCENTAGE=50

# --- Admin / Cron ---
# Secret para autenticar chamadas do Vercel Cron
CRON_SECRET=
# E-mails de admins iniciais (separados por vírgula)
PLATFORM_ADMIN_EMAILS=

# --- Upstash Redis (hold de slots) ---
# https://upstash.com/ — free tier 10k cmd/dia
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Resend (e-mail) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Joga Fácil <noreply@jogafacil.com.br>

# --- Observabilidade ---
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Flags de dev ---
# Use mock=1 para rodar sem dependências externas (apenas dev/scaffold)
MOCK_AUTH=1
MOCK_PAYMENTS=1
MOCK_EMAIL=1
